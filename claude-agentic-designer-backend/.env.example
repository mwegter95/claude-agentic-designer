# ─── Claude Agentic Designer — Backend / Skill configuration ───────────────────
# Copy this file to `.env` and adjust as needed. All values are optional and have
# safe defaults so the workflow runs locally with no cloud dependencies.

# Local event/orchestration server (FastAPI). The skill tool scripts POST events
# here; the React frontend subscribes to its SSE stream.
CLAUDE_DESIGNER_HOST=127.0.0.1
CLAUDE_DESIGNER_PORT=8787
# Where skill scripts try to POST events (best-effort; JSONL is always written).
CLAUDE_DESIGNER_EVENT_URL=http://127.0.0.1:8787/api/ingest

# Root folder for runtime data (reference library, runs, artifacts).
# Defaults to ./workspace inside this repo.
CLAUDE_DESIGNER_WORKSPACE=

# Path to the LibreOffice "soffice" binary used to render .pptx -> .png.
# Leave blank to auto-detect (macOS app bundle / PATH).
SOFFICE_BIN=

# ─── Microsoft 365 / SharePoint (Microsoft Graph) ─────────────────────────────
# Optional. Enables pulling the master deck + examples from SharePoint/OneDrive.
# Uses MSAL device-code flow (no client secret required for a public client app).
# Register an app in Entra ID with delegated Files.Read.All / Sites.Read.All.
GRAPH_CLIENT_ID=
GRAPH_TENANT_ID=common
GRAPH_SCOPES=Files.Read.All Sites.Read.All
